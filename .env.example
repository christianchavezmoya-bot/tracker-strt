# HOLO-RTLS — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
JWT_SECRET_KEY=replace-with-another-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — single file, no server needed):
DATABASE_URL=sqlite:///data/holo_rtls.db
# PostgreSQL (for production scale):
# DATABASE_URL=postgresql://user:password@localhost:5432/holo_rtls

# ── Security ──────────────────────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=3
LOGIN_LOCKOUT_SECONDS=300
JWT_ACCESS_TOKEN_MINUTES=240
JWT_REFRESH_TOKEN_DAYS=7

# ── Mail / SMTP ───────────────────────────────────────────────────────────────
MAIL_ENABLED=0
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=alerts@yourdomain.com
FLASK_MAIL_SUPPRESS_SEND=1   # Set to 0 in production

# ── SMS (Twilio) ─────────────────────────────────────────────────────────────
SMS_ENABLED=0
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890

# ── MQTT ──────────────────────────────────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_BROKER_USERNAME=
MQTT_BROKER_PASSWORD=
MQTT_USE_TLS=0

# ── UWB / Positioning ─────────────────────────────────────────────────────────
USE_MOCK_UWB=1
UWB_SERIAL_PORT=/dev/ttyUSB0
UWB_BAUD_RATE=115200

# ── Business Defaults ─────────────────────────────────────────────────────────
DEFAULT_FACILITY_NAME=My Facility
DEFAULT_TIMEZONE=UTC
DEFAULT_MAP_SCALE=100

# ── Alert Thresholds ──────────────────────────────────────────────────────────
DEFAULT_BATTERY_CRITICAL_PCT=15
DEFAULT_NO_SIGNAL_TIMEOUT_SECS=120
DEFAULT_NO_MOVEMENT_THRESHOLD_M=0.5
DEFAULT_NO_MOVEMENT_CHECK_INTERVAL_SECS=300

# ── Application ────────────────────────────────────────────────────────────────
FLASK_DEBUG=1
FLASK_ENV=development
CORS_ORIGINS=http://localhost:8080   # Use * for any origin in dev

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_RETENTION_COUNT=10
